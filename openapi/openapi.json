    "/routines/{routine_id}/fields/{field_key}/resolve": {
      "post": {
        "tags": [
          "Routines"
        ],
        "summary": "Resolve a configured routine field value",
        "description": "Requires Cognito authentication and organization membership.",
        "operationId": "resolveRoutineField",
        "security": [
          {
            "cognitoAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "routine_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "field_key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResolveRoutineFieldRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResolveRoutineFieldResponse"
                }
              }
            },
            "description": "Resolved field value or validation result."
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Invalid request body or parameters."
      },
      "Forbidden": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Organization membership or admin access is required."
      },
      "NotFound": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Resource not found."
      },
      "RateLimited": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Rate limit exceeded."
      },
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Missing or invalid credentials."
      }
    },
    "schemas": {
      "CreateOrderRequest": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/OrderItemInput"
            },
            "type": "array"
          },
          "order_number": {
            "type": "string"
          }
        },
        "required": [
          "order_number"
        ],
        "type": "object"
      },
      "CreateRoutineRequest": {
        "properties": {
          "code": {
            "type": "string"
          },
          "config": {
            "$ref": "#/components/schemas/RoutineConfig"
          },
          "description": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "name",
          "config"
        ],
        "type": "object"
      },
      "CreateSkuRequest": {
        "properties": {
          "attributes": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "barcode": {
            "type": "string"
          },
          "brand": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "image_url": {
            "type": "string"
          },
          "product_title": {
            "type": "string"
          },
          "rfids": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "size": {
            "type": "string"
          },
          "sku_code": {
            "type": "string"
          },
          "variant_label": {
            "type": "string"
          }
        },
        "required": [
          "sku_code"
        ],
        "type": "object"
      },
      "Device": {
        "properties": {
          "created_at": {
            "format": "date-time",
            "type": "string"
          },
          "device_type": {
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "type": "string"
          },
          "last_seen_at": {
            "format": "date-time",
            "nullable": true,
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "org_id": {
            "format": "uuid",
            "type": "string"
          },
          "serial_number": {
            "type": "string"
          },
          "status": {
            "enum": [
              "active",
              "inactive",
              "decommissioned"
            ],
            "type": "string"
          },
          "updated_at": {
            "format": "date-time",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Error": {
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "GenerateSessionRequest": {
        "properties": {
          "description": {
            "description": "Natural-language description of the session to generate.",
            "type": "string"
          }
        },
        "required": [
          "description"
        ],
        "type": "object"
      },
      "GenerateSessionResponse": {
        "properties": {
          "metadata": {
            "additionalProperties": true,
            "type": "object"
          },
          "rfid_entries": {
            "items": {
              "$ref": "#/components/schemas/GeneratedRfidEntry"
            },
